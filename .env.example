# Supabase (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # NUNCA exponha no client

# Mercado Pago (Suas integrações > Credenciais — use as de teste em dev)
MP_ACCESS_TOKEN=APP_USR-...
# Assinatura secreta exibida ao configurar o webhook no painel do MP
# (produção; sem ela o webhook aceita notificações sem validar)
MP_WEBHOOK_SECRET=

# Resend (e-mail transacional)
RESEND_API_KEY=re_...
EMAIL_FROM="Nossa Retro <ola@seudominio.com.br>"

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
